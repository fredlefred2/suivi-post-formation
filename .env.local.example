# Supabase — Récupérer sur https://app.supabase.com > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Resend — Récupérer sur https://resend.com > API Keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# URL de l'application (pour les liens dans les emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret pour protéger la route cron (générer une chaîne aléatoire)
CRON_SECRET=votre_secret_aleatoire_ici
